{
  "name": "@ternent/concord",
  "version": "0.2.2",
  "description": "Command-driven developer runtime for building non-custodial apps on @ternent/ledger",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "pnpm --filter @ternent/rage build && vitest run"
  },
  "dependencies": {
    "@ternent/ledger": "workspace:*"
  },
  "devDependencies": {
    "@ternent/armour": "workspace:*",
    "@ternent/identity": "workspace:*",
    "@ternent/rage": "workspace:*",
    "@ternent/seal-cli": "workspace:*",
    "@types/node": "^24.3.0",
    "typescript": "^5.6.3",
    "vite": "^4.5.3",
    "vite-plugin-dts": "^1.7.3",
    "vitest": "^1.6.0"
  }
}

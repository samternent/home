{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@ternent/pixpax-core": ["../pixpax-core/dist/index.d.ts"],
      "@ternent/seal-cli/proof": ["src/shims/seal-cli-proof.d.ts"]

{
  "name": "home",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "hello@ternent.dev",
  "license": "ISC",
  "engines": {
    "node": ">=20",
    "pnpm": "^8.6.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.27.7",
    "encoding": "0.1.13"
  },
  "dependencies": {
    "shelljs": "^0.8.5",
    "yaml": "^2.5.0"
  },
  "scripts": {
    "prepare:ternent-app": "node scripts/prepare-ternent-app.mjs",
    "scaffold:ternent-app": "node scripts/scaffold-ternent-app.mjs",
    "sync:ternent-app": "node scripts/sync-ternent-app.mjs",
    "setup:ternent-app-deploy": "node scripts/setup-ternent-app-deploy.mjs",
    "test:ternent-app-scaffold": "node --test scripts/tests/ternent-app-manifest.test.mjs scripts/tests/scaffold-ternent-app.test.mjs scripts/tests/prepare-ternent-app.test.mjs",
    "build:footballsocial": "pnpm --filter footballsocial build",
    "build:seal": "pnpm --filter ternent-ui --filter ternent-utils --filter @ternent/identity --filter @ternent/seal-cli --filter seal build",
    "build:ternentdotdev": "pnpm --filter ternentdotdev build",
    "dev:footballsocial": "pnpm --filter footballsocial dev",
    "dev:seal": "pnpm --filter seal dev",
    "dev:ternentdotdev": "pnpm --filter ternentdotdev dev",
    "dev:ternent-ui": "pnpm --filter ternent-ui dev",
    "build:footballsocial-api": "docker build -f ./apps/footballsocial-api/Dockerfile . -t samternent/footballsocial-api",
    "build:ternent-api-libs": "pnpm --filter ternent-utils --filter @ternent/concord-protocol --filter @ternent/identity --filter ternent-identity build",
    "build:ternent-api": "docker build -f ./apps/ternent-api/Dockerfile . -t samternent/ternent-api",
    "build:slides": "pnpm --filter ternentdotdev build:slides:teamwork-frontend && pnpm --filter ternentdotdev build:slides:router-drawers && pnpm --filter ternentdotdev build:slides:copy",
    "build:libs": "pnpm --filter ternent-ui --filter ternent-utils --filter @ternent/identity --filter @ternent/concord-protocol --filter @ternent/concord-protocol-wasm  --filter ternent-identity --filter ternent-encrypt --filter @ternent/concord-plugin-identity --filter @ternent/concord-plugin-encryption --filter @ternent/concord-plugin-permissions --filter ternent-ledger build",
    "build:ternent-ui": "pnpm --filter ternent-ui build",
    "generate-docs": "node scripts/generate-docs.js",
    "enhance-docs": "node scripts/enhance-docs.js",
    "generate:stickerbook-pack": "node scripts/stickerbook/generate-pack.mjs",
    "generate:stickerbook-pack:8bit": "SERIES_ID=SERIES-8BIT node scripts/stickerbook/generate-pack.mjs",
    "generate:stickerbook-pack:animal-8bit": "SERIES_ID=SERIES-ANIMAL-ARCHETYPE-8BIT node scripts/stickerbook/generate-pack.mjs",
    "generate:pixpax:all": "pnpm run generate:stickerbook-pack:8bit && pnpm run generate:stickerbook-pack:animal-8bit",
    "pixpax:verify": "pnpm --filter ternent-api pixpax:verify",
    "pixpax:verify-pack": "pnpm --filter ternent-api pixpax:verify-pack",
    "pixpax:derive-issuer-key-formats": "pnpm --filter ternent-api pixpax:derive-issuer-key-formats",
    "derive:issuer-public-key": "pnpm run pixpax:derive-issuer-key-formats",
    "docs": "npm run generate-docs && npm run enhance-docs",
    "dev:docker": "cd .ops && env -u DOCKER_DEFAULT_PLATFORM docker-compose up -d"
  },
  "pnpm": {
    "patchedDependencies": {}
  },
  "packageManager": "pnpm@8.15.5+sha1.a58c038faac410c947dbdb93eb30994037d0fce2"
}
